{
  "name": "randi-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "cleanup": "npx tsx scripts/cleanup-containers.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "validate:skills": "tsx scripts/validate-skills.ts",
    "employee:auditor": "tsx scripts/employee-auditor.ts",
    "employee:leadgen": "tsx scripts/employee-lead-gen.ts",
    "employee:seo": "tsx scripts/employee-seo-scout.ts",
    "self-maintenance": "tsx src/lib/self-maintenance/index.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/openai": "^3.0.37",
    "@ai-sdk/react": "^3.0.108",
