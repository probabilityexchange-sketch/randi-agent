    "@solana-program/token": "latest",
    "@solana/kit": "latest",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.98.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "ai": "^6.0.116",
    "bs58": "^6.0.0",
    "dockerode": "^4.0.9",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.0",
    "nanoid": "^5.1.6",
    "next": "^16.1.6",
    "openai": "^6.27.0",
    "pg": "^8.16.3",
    "prisma": "^7.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
