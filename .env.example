# =============================================================================
# SUPABASE DATABASE
# =============================================================================
# Connection to Supabase PostgreSQL via pgBouncer pooler (port 5432)
# The pooler URL is automatically patched by src/lib/db/prisma.ts:
# - Adds ?pgbouncer=true, ?sslmode=require
# - Converts username "postgres" to "postgres.<projectRef>"
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Direct connection to Supabase (database host, port 5432).
# This is typically IPv6-only. If your build environment is IPv4-only, use
# the session pooler above for schema pushes and runtime traffic.
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Supabase project reference (used for connection patching)
SUPABASE_URL="https://<project-ref>.supabase.co"

# =============================================================================
# LOCAL DEVELOPMENT (overrides for running against local PostgreSQL)
# =============================================================================
# DATABASE_URL="postgresql://agentplatform:agentplatform@localhost:5432/agentplatform?schema=public"

# Next.js
NEXT_PUBLIC_DOMAIN="localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_X_URL="https://x.com/yourhandle"
NEXT_PUBLIC_COMPOSIO_TOOLS_URL="https://composio.dev/tools"
NEXTAUTH_SECRET="change-me-in-production"
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
KILO_API_KEY=""
KILO_DEFAULT_MODEL="meta-llama/llama-3.3-70b-instruct:free"
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="meta-llama/llama-3.3-70b-instruct:free"
COMPOSIO_API_KEY=""
# Admin API secret — used by /api/admin/* endpoints (must be a strong random secret, leave blank to disable)
ADMIN_SECRET=""
# Optional shared Composio entity across all app users (leave blank for per-user connections)
COMPOSIO_ENTITY_ID=""
# Optional auth config overrides (otherwise first enabled config per toolkit is used)
COMPOSIO_AUTH_CONFIG_GITHUB=""
COMPOSIO_AUTH_CONFIG_SLACK=""
COMPOSIO_AUTH_CONFIG_NOTION=""
COMPOSIO_AUTH_CONFIG_GMAIL=""
COMPOSIO_AUTH_CONFIG_GOOGLESHEETS=""
COMPOSIO_AUTH_CONFIG_PROMPMATE=""
COMPOSIO_AUTH_CONFIG_COINMARKETCAP=""
COMPOSIO_AUTH_CONFIG_GOOGLECALENDAR=""
COMPOSIO_AUTH_CONFIG_SUPABASE=""
COMPOSIO_AUTH_CONFIG_VERCEL=""

# JWT
JWT_SECRET="change-me-32-char-minimum-secret-key"

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# Solana
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_CLUSTER="devnet"
CONFIRMATION_LEVEL="confirmed"

# SPL Token (Pump.fun token - set when created)
NEXT_PUBLIC_TOKEN_MINT="FYAz1bPKJUFRwT4pzhUzdN3UqCN5ppXRL2pfto4zpump"
TOKEN_MINT="FYAz1bPKJUFRwT4pzhUzdN3UqCN5ppXRL2pfto4zpump"
TOKEN_DECIMALS="9"
NEXT_PUBLIC_TOKEN_DECIMALS="9"
TREASURY_WALLET="8aCejvT33eXNb6bUd74F4hALd8e9xjGfYsufyFkYAkqX"
# Optional mint used only for SOL-mode USD pricing quotes (default: wrapped SOL)
SOL_PRICE_MINT="So11111111111111111111111111111111111111112"

# Payment asset mode: "spl" (SPL token mint) or "sol" (native SOL)
PAYMENT_ASSET="spl"
# Burn recipient for SOL-mode payments (default is Solana incinerator)
SOL_BURN_WALLET="1nc1nerator11111111111111111111111111111111"

# Token packs are defined in src/lib/tokenomics.ts — no env vars needed for amounts

# Token pricing and payment split
# Optional manual override for token price in USD (ex: "0.000123")
TOKEN_USD_PRICE_OVERRIDE=""
# Cache window for external price quote (milliseconds)
TOKEN_PRICE_CACHE_MS="20000"
# Minimum pool liquidity (USD) required when selecting DexScreener price pairs
TOKEN_PRICE_MIN_LIQUIDITY_USD="5000"
# Optional comma-separated DexScreener pair addresses to allowlist for pricing
TOKEN_PRICE_ALLOWED_PAIR_ADDRESSES=""
# Basis points to burn from each USAGE payment
# Phase 1 Ignition = 7000 (70% burn). Update as phases progress.
PAYMENT_BURN_BPS="7000"
# Purchase intent lifetime before verify rejects it (milliseconds)
PURCHASE_INTENT_TTL_MS="900000"

# Docker
DOCKER_SOCKET="/var/run/docker.sock"
DOCKER_HOST="http://docker-proxy:2375"
DOCKER_NETWORK="traefik-net"

# Traefik
TRAEFIK_NETWORK="traefik-net"

# Container defaults
CONTAINER_MAX_MEMORY="4294967296"
CONTAINER_MAX_CPU="2000000000"
CONTAINER_PID_LIMIT="256"
CONTAINER_DEFAULT_HOURS="4"
# Provision launch rate limit (per user)
RATE_LIMIT_PROVISION_MAX_REQUESTS="6"
RATE_LIMIT_PROVISION_WINDOW_MS="60000"
# Purchase verify rate limit (per user)
RATE_LIMIT_PURCHASE_VERIFY_MAX_REQUESTS="12"
RATE_LIMIT_PURCHASE_VERIFY_WINDOW_MS="60000"

# Agent images
AGENT_ZERO_IMAGE="frdel/agent-zero:latest"
OPENCLAW_IMAGE="openclaw/openclaw:latest"

# Persist per-user/per-agent container data volumes across launches
AGENT_PERSISTENT_STORAGE="true"

# Optional distributed rate limiting (recommended for multi-instance deployment)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare (for Traefik DNS challenge)
CF_API_EMAIL="your@email.com"
CF_DNS_API_TOKEN="your-cloudflare-api-token"

# =============================================================================
# AGENTCARD INTEGRATION
# =============================================================================
AGENTCARD_API_KEY=       # AgentCard API key
AGENTCARD_BASE_URL=     # AgentCard API base URL (if self-hosted)

# Firehose — real-time web monitoring
FIREHOSE_MANAGEMENT_KEY=fhm_your_management_key_here
FIREHOSE_TAP_TOKEN=fh_your_tap_token_here
