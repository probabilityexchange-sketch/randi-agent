# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production
!.env.example

# keypairs - NEVER commit
*-keypair.json
*.keypair

# traefik certs
traefik/acme/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# kombai
.kombai/
.env*.local

# local data
/prisma/*.db
/prisma/*.db-journal
/aws/
/dist/

# temp/tooling
.pi/
.kilocode/
.agent/
.agents/
.claude/
.kombai/
*.tmp
*.log
awscliv2.zip
verified_deposits.txt
evals/.env
