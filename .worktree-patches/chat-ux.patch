+++ b/src/lib/chat/errors.test.ts
@@ -0,0 +1,248 @@
+import test from "node:test";
+import assert from "node:assert/strict";
+
+import {
+  isApiError,
+  parseApprovalRequiredError,
+  isApprovalRequiredError,
+  isInsufficientCreditsError,
+  isValidationError,
+  isNotFoundError,
+  createUserSafeErrorMessage,
+  getErrorCode,
+  getErrorStatus,
+  type ApiError,
+  type ErrorCode,
+} from "@/lib/chat/errors";
+
+test("isApiError returns true for valid ApiError object", () => {
+  const error: unknown = {
+    error: "Something went wrong",
+    code: "INTERNAL_ERROR"
+  };
+  
+  assert.equal(isApiError(error), true);
+});
+
+test("isApiError returns false for objects missing required fields", () => {
+  assert.equal(isApiError({ error: "Only error" }), false);
+  assert.equal(isApiError({ code: "ERROR" }), false);
+  assert.equal(isApiError({}), false);
+  assert.equal(isApiError(null), false);
+  assert.equal(isApiError(undefined), false);
+  assert.equal(isApiError("string error"), false);
+  assert.equal(isApiError(123), false);
+});
+
+test("parseApprovalRequiredError extracts tool name and args", () => {
+  const error = new Error('APPROVAL_REQUIRED|github_create_issue|{"repo":"test","title":"bug report"}');
+  const result = parseApprovalRequiredError(error);
+  
+  assert.equal(result.toolName, "github_create_issue");
+  assert.deepEqual(result.args, { repo: "test", title: "bug report" });
+});
+
+test("parseApprovalRequiredError handles missing args", () => {
+  const error = new Error('APPROVAL_REQUIRED|send_email');
+  const result = parseApprovalRequiredError(error);
+  
+  assert.equal(result.toolName, "send_email");
+  assert.deepEqual(result.args, {});
+});
+
+test("parseApprovalRequiredError handles invalid JSON args gracefully", () => {
+  const error = new Error('APPROVAL_REQUIRED|test_tool|not valid json');
+  const result = parseApprovalRequiredError(error);
+  
+  assert.equal(result.toolName, "test_tool");
+  assert.deepEqual(result.args, { raw: "not valid json" });
+});
+
+test("parseApprovalRequiredError handles empty message parts", () => {
+  const error = new Error('APPROVAL_REQUIRED|');
+  const result = parseApprovalRequiredError(error);
+  
+  assert.equal(result.toolName, "unknown");
+  assert.deepEqual(result.args, {});
+});
+
+test("parseApprovalRequiredError handles arbitrary error message", () => {
+  const error = new Error('Some other error');
+  const result = parseApprovalRequiredError(error);
+  
+  assert.equal(result.toolName, "unknown");
+  assert.deepEqual(result.args, {});
+});
+
+test("isApiError handles all ErrorCode types", () => {
+  const errorCodes: Array<ApiError["code"]> = [
+    "VALIDATION_ERROR",
+    "AUTH_ERROR", 
+    "SESSION_NOT_FOUND",
+    "AGENT_NOT_FOUND",
+    "INSUFFICIENT_FUNDS",
+    "APPROVAL_REQUIRED",
+    "TOOL_EXECUTION_FAILED",
+    "MODEL_UNAVAILABLE",
+    "INTERNAL_ERROR"
+  ];
+
+  errorCodes.forEach((code) => {
+    const error: unknown = { error: "test", code };
+    assert.equal(isApiError(error), true, `Should recognize ${code} as ApiError`);
+  });
+});
+
+test("isApprovalRequiredError detects approval required errors", () => {
+  const approvalError = new Error("APPROVAL_REQUIRED|github_create_issue|{}");
+  assert.equal(isApprovalRequiredError(approvalError), true);
+  
+  const otherError = new Error("Some other error");
+  assert.equal(isApprovalRequiredError(otherError), false);
+  
+  const emptyError = new Error("");
+  assert.equal(isApprovalRequiredError(emptyError), false);
+});
+
+test("isInsufficientCreditsError detects credit errors", () => {
+  const creditError = new Error("Insufficient credits for this operation");
+  assert.equal(isInsufficientCreditsError(creditError), true);
+  
+  const otherError = new Error("Some other error");
+  assert.equal(isInsufficientCreditsError(otherError), false);
+});
+
+test("isValidationError detects validation errors", () => {
+  const zodError = new Error("ZodError: validation failed");
+  assert.equal(isValidationError(zodError), true);
+  
+  const validationError = new Error("validation error occurred");
+  assert.equal(isValidationError(validationError), true);
+  
+  const otherError = new Error("Some other error");
+  assert.equal(isValidationError(otherError), false);
+});
+
+test("isNotFoundError detects not found errors", () => {
+  const notFoundError = new Error("NotFoundError: Record not found");
+  assert.equal(isNotFoundError(notFoundError), true);
+  
+  const recordError = new Error("Record to update not found");
+  assert.equal(isNotFoundError(recordError), true);
+  
+  const otherError = new Error("Some other error");
+  assert.equal(isNotFoundError(otherError), false);
+});
+
+test("createUserSafeErrorMessage returns user-safe messages for known errors", () => {
+  const approvalError = new Error("APPROVAL_REQUIRED|send_email|{}");
+  const approvalMsg = createUserSafeErrorMessage(approvalError);
+  assert.equal(approvalMsg, 'Tool "send_email" requires your approval before executing.');
+  
+  const creditError = new Error("Insufficient credits for this operation");
+  const creditMsg = createUserSafeErrorMessage(creditError);
+  assert.equal(creditMsg, "Insufficient credits to complete this request. Please add more credits to continue.");
+  
+  const validationError = new Error("validation failed");
+  const validationMsg = createUserSafeErrorMessage(validationError);
+  assert.equal(validationMsg, "Invalid request data. Please check your input.");
+  
+  const notFoundError = new Error("NotFoundError: Record not found");
+  const notFoundMsg = createUserSafeErrorMessage(notFoundError);
+  assert.equal(notFoundMsg, "The requested resource was not found.");
+});
+
+test("createUserSafeErrorMessage returns generic message for unknown errors", () => {
+  const unknownError = new Error("Something completely unexpected");
+  const msg = createUserSafeErrorMessage(unknownError);
+  assert.equal(msg, "An unexpected error occurred. Please try again.");
+  
+  const nonError = createUserSafeErrorMessage("string error");
+  assert.equal(nonError, "An unexpected error occurred. Please try again.");
+  
+  const nullError = createUserSafeErrorMessage(null);
+  assert.equal(nullError, "An unexpected error occurred. Please try again.");
+});
+
+test("getErrorCode returns correct codes for different error types", () => {
+  const approvalError = new Error("APPROVAL_REQUIRED|test_tool|{}");
+  assert.equal(getErrorCode(approvalError), "APPROVAL_REQUIRED");
+  
+  const creditError = new Error("Insufficient credits");
+  assert.equal(getErrorCode(creditError), "INSUFFICIENT_FUNDS");
+  
+  const validationError = new Error("validation failed");
+  assert.equal(getErrorCode(validationError), "VALIDATION_ERROR");
+  
+  const notFoundError = new Error("NotFoundError");
+  assert.equal(getErrorCode(notFoundError), "SESSION_NOT_FOUND");
+  
+  const apiError: unknown = { error: "test", code: "AUTH_ERROR" };
+  assert.equal(getErrorCode(apiError), "AUTH_ERROR");
+  
+  const unknownError = new Error("Some unknown error");
+  assert.equal(getErrorCode(unknownError), "INTERNAL_ERROR");
+});
+
+test("getErrorStatus returns correct HTTP status codes", () => {
+  assert.equal(getErrorStatus("APPROVAL_REQUIRED"), 202);
+  assert.equal(getErrorStatus("INSUFFICIENT_FUNDS"), 402);
+  assert.equal(getErrorStatus("AUTH_ERROR"), 401);
+  assert.equal(getErrorStatus("VALIDATION_ERROR"), 400);
+  assert.equal(getErrorStatus("SESSION_NOT_FOUND"), 404);
+  assert.equal(getErrorStatus("AGENT_NOT_FOUND"), 404);
+  assert.equal(getErrorStatus("MODEL_UNAVAILABLE"), 404);
+  assert.equal(getErrorStatus("TOOL_EXECUTION_FAILED"), 500);
+  assert.equal(getErrorStatus("INTERNAL_ERROR"), 500);
+});
+
+test("error classification helpers work together for route error handling", () => {
+  const testCases = [
+    { 
+      error: new Error("APPROVAL_REQUIRED|github_create_issue|{}"),
+      expectedCode: "APPROVAL_REQUIRED",
+      expectedStatus: 202,
+      expectSafeMessage: true
+    },
+    { 
+      error: new Error("Insufficient credits for this request"),
+      expectedCode: "INSUFFICIENT_FUNDS",
+      expectedStatus: 402,
+      expectSafeMessage: true
+    },
+    { 
+      error: new Error("ZodError: Invalid input"),
+      expectedCode: "VALIDATION_ERROR",
+      expectedStatus: 400,
+      expectSafeMessage: true
+    },
+    { 
+      error: new Error("NotFoundError: Session not found"),
+      expectedCode: "SESSION_NOT_FOUND",
+      expectedStatus: 404,
+      expectSafeMessage: true
+    },
+    {
+      error: new Error("Unexpected internal error"),
+      expectedCode: "INTERNAL_ERROR",
+      expectedStatus: 500,
+      expectSafeMessage: true
+    }
+  ];
+
+  testCases.forEach((tc) => {
+    const code = getErrorCode(tc.error);
+    assert.equal(code, tc.expectedCode, `Code mismatch for: ${tc.error.message}`);
+    
+    const status = getErrorStatus(code);
+    assert.equal(status, tc.expectedStatus, `Status mismatch for: ${tc.error.message}`);
+    
+    const msg = createUserSafeErrorMessage(tc.error);
+    assert.equal(msg.includes("requires your approval") || 
+                 msg.includes("Insufficient credits") || 
+                 msg.includes("Invalid request") || 
+                 msg.includes("resource was not found") ||
+                 msg.includes("unexpected error"), true, 
+                 `Safe message check for: ${tc.error.message}`);
+  });
+});
