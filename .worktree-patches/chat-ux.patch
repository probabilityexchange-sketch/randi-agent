+++ b/src/lib/chat/errors.ts
@@ -0,0 +1,131 @@
+import { NextResponse } from "next/server";
+
+export type ErrorCode =
+  | "VALIDATION_ERROR"
+  | "AUTH_ERROR"
+  | "SESSION_NOT_FOUND"
+  | "AGENT_NOT_FOUND"
+  | "INSUFFICIENT_FUNDS"
+  | "APPROVAL_REQUIRED"
+  | "TOOL_EXECUTION_FAILED"
+  | "MODEL_UNAVAILABLE"
+  | "INTERNAL_ERROR";
+
+export interface ApiError {
+  error: string;
+  code: ErrorCode;
+  details?: string;
+  toolName?: string;
+  toolArgs?: Record<string, unknown>;
+  description?: string;
+}
+
+export function isApiError(error: unknown): error is ApiError {
+  return (
+    typeof error === "object" &&
+    error !== null &&
+    "code" in error &&
+    "error" in error
+  );
+}
+
+export function parseApprovalRequiredError(error: Error): {
+  toolName: string;
+  args: Record<string, unknown>;
+} {
+  const parts = error.message.split("|");
+  const toolName = parts[1] || "unknown";
+  let args: Record<string, unknown> = {};
+  
+  try {
+    if (parts[2]) {
+      args = JSON.parse(parts[2]);
+    }
+  } catch {
+    args = { raw: parts[2] };
+  }
+
+  return { toolName, args };
+}
+
+export function isApprovalRequiredError(error: Error): boolean {
+  return error.message.startsWith("APPROVAL_REQUIRED|");
+}
+
+export function isInsufficientCreditsError(error: Error): boolean {
+  return error.message.includes("Insufficient credits");
+}
+
+export function isValidationError(error: Error): boolean {
+  return error.message.includes("validation") || error.message.includes("ZodError");
+}
+
+export function isNotFoundError(error: Error): boolean {
+  return error.message.includes("NotFoundError") || error.message.includes("Record to update not found");
+}
+
+export function createUserSafeErrorMessage(error: unknown): string {
+  if (error instanceof Error) {
+    if (isApprovalRequiredError(error)) {
+      const { toolName } = parseApprovalRequiredError(error);
+      return `Tool "${toolName}" requires your approval before executing.`;
+    }
+    if (isInsufficientCreditsError(error)) {
+      return "Insufficient credits to complete this request. Please add more credits to continue.";
+    }
+    if (isValidationError(error)) {
+      return "Invalid request data. Please check your input.";
+    }
+    if (isNotFoundError(error)) {
+      return "The requested resource was not found.";
+    }
+  }
+  return "An unexpected error occurred. Please try again.";
+}
+
+export function getErrorCode(error: unknown): ErrorCode {
+  if (isApiError(error)) {
+    return error.code;
+  }
+  if (error instanceof Error) {
+    if (isApprovalRequiredError(error)) return "APPROVAL_REQUIRED";
+    if (isInsufficientCreditsError(error)) return "INSUFFICIENT_FUNDS";
+    if (isValidationError(error)) return "VALIDATION_ERROR";
+    if (isNotFoundError(error)) return "SESSION_NOT_FOUND";
+  }
+  return "INTERNAL_ERROR";
+}
+
+export function getErrorStatus(code: ErrorCode): number {
+  switch (code) {
+    case "APPROVAL_REQUIRED":
+      return 202;
+    case "INSUFFICIENT_FUNDS":
+      return 402;
+    case "AUTH_ERROR":
+      return 401;
+    case "VALIDATION_ERROR":
+      return 400;
+    case "SESSION_NOT_FOUND":
+    case "AGENT_NOT_FOUND":
+    case "MODEL_UNAVAILABLE":
+      return 404;
+    case "TOOL_EXECUTION_FAILED":
+      return 500;
+    case "INTERNAL_ERROR":
+    default:
+      return 500;
+  }
+}
+
+export function createErrorResponse(
+  message: string,
+  code: ErrorCode,
+  status: number,
+  extras?: Partial<ApiError>
+): NextResponse<ApiError> {
+  return NextResponse.json(
+    { error: message, code, ...extras },
+    { status }
+  );
+}
